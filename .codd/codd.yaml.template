# CoDD Configuration Template for AI-DLC × CoDD projects
#
# Copy this file to .codd/codd.yaml and customize for your project.
#   cp .codd/codd.yaml.template .codd/codd.yaml
#
# Then edit the fields marked "CHANGE THIS" before running:
#   codd init --project-name "<name>" --language <lang> --dest .
#   codd scan --path .

# Schema version — do not change
version: "0.2.0a1"

project:
  name: "your-project-name"  # CHANGE THIS: your project name
  language: "python"         # CHANGE THIS: python | typescript | java | go
  frameworks: []             # Optional: ["django", "fastapi", "react", etc.]

# AI command for CoDD analysis (optimized for AI-DLC × CoDD)
# Do not change unless you are using a different Claude model.
ai_command: "claude --print --model claude-opus-4-6 --tools \"\""

scan:
  # Document directories containing CoDD-managed Markdown files.
  # AI-DLC × CoDD default: aidlc-docs/ (change if your project uses a different path)
  # codd/extracted/ contains L1-L6 documents generated by `codd extract --ai`.
  # Include it here so that `codd scan` processes those files and their `source_files:`
  # frontmatter creates doc→code edges (the mechanism for Source Coverage in codd measure).
  # Adjust path to .codd/extracted/ if your codd.yaml lives in .codd/ instead of codd/.
  doc_dirs:
    - "aidlc-docs/"
    - ".codd/extracted/"    # L1-L6 files from `codd extract --ai` (AI-DLC × CoDD uses .codd/ by convention)

  # ⚠️ REQUIRED CHANGE: Replace with your actual source code directory.
  # Leaving the default "src/" causes Phase 1 to scan 0 files, which means
  # codd extract --ai cannot analyze any code and produces no useful output.
  #
  # Examples:
  #   - Code under source/    → "source/"
  #   - Code under backend/src/ → "backend/src/"
  #   - Code at project root   → "."  (NOT recommended — see warning below)
  #
  # ⚠️ WARNING — node_modules / large vendor directories:
  # If source_dirs contains a directory that includes node_modules (e.g., "."),
  # `codd measure` will count ALL files under that directory (including node_modules)
  # as the coverage denominator — potentially reporting 0/7000+ instead of the
  # actual source coverage. The exclude patterns above apply to `codd scan` but
  # do NOT exclude vendor directories from `codd measure`'s file count denominator.
  # Solution: Always point source_dirs at your actual application source directory,
  # NOT at the project root when node_modules or large vendor dirs live there.
  source_dirs:
    - "src/"   # ← ⚠️ CHANGE THIS to your actual source directory (NOT "." if node_modules is present)

  # Test directories
  test_dirs:
    - "tests/"

  # Additional config files to include in the scan (optional)
  config_files: []

  # Glob patterns to exclude from scanning
  exclude:
    - "**/node_modules/**"
    - "**/__pycache__/**"
    - "**/dist/**"
    - "**/*.pyc"

graph:
  store: "jsonl"
  # Graph storage path — AI-DLC × CoDD convention uses .codd/ as the config directory.
  # If you used 'codd init' (default, non-hidden), change this to: path: "codd/scan"
  path: ".codd/scan"

bands:
  green:
    min_confidence: 0.90   # Auto-update threshold (high confidence)
    min_evidence_count: 2
  amber:
    min_confidence: 0.50   # Human-review threshold (plausible impact)

propagation:
  max_depth: 10
  stop_at_contract_boundary: true
